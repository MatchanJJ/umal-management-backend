  {
    "category": "Multi-Turn Conversation",
    "type": "multi_turn",
    "test_id": "multiturn_001",
    "description": "Progressive modifier chain: count -> gender modifier -> experience modifier",
    "conversation": [
      {
        "turn": 1,
        "input": "I need 3 volunteers",
        "description": "Initial count-only request",
        "merge_action": "initial",
        "expected_parse": {"groups": [{"count": 3}], "global": {"conflict_ok": false}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 3}], "global": {"conflict_ok": false, "priority_rules": []}, "is_confirming": false}
      },
      {
        "turn": 2,
        "input": "Female please",
        "description": "Modifier: patches gender=F, count must be preserved",
        "merge_action": "modifier",
        "expected_parse": {"groups": [{"gender": "F"}], "global": {"conflict_ok": false}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 3, "gender": "F"}], "global": {"conflict_ok": false, "priority_rules": []}, "is_confirming": false}
      },
      {
        "turn": 3,
        "input": "New members only",
        "description": "Modifier: patches new_old=new, count and gender both preserved",
        "merge_action": "modifier",
        "expected_parse": {"groups": [{"new_old": "new"}], "global": {"conflict_ok": false}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 3, "gender": "F", "new_old": "new"}], "global": {"conflict_ok": false, "priority_rules": []}, "is_confirming": false}
      }
    ]
  },
  {
    "category": "Multi-Turn Conversation",
    "type": "multi_turn",
    "test_id": "multiturn_002",
    "description": "Priority accumulation: count -> add priority rule -> flip conflict_ok and add second rule",
    "conversation": [
      {
        "turn": 1,
        "input": "Need 5 people",
        "description": "Initial count request",
        "merge_action": "initial",
        "expected_parse": {"groups": [{"count": 5}], "global": {"conflict_ok": false}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 5}], "global": {"conflict_ok": false, "priority_rules": []}, "is_confirming": false}
      },
      {
        "turn": 2,
        "input": "Males first please",
        "description": "Modifier: patches gender=M and adds male_first priority rule",
        "merge_action": "modifier",
        "expected_parse": {"groups": [{"gender": "M"}], "global": {"conflict_ok": false, "priority_rules": ["male_first"]}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 5, "gender": "M"}], "global": {"conflict_ok": false, "priority_rules": ["male_first"]}, "is_confirming": false}
      },
      {
        "turn": 3,
        "input": "Attendance takes priority, class conflicts are fine",
        "description": "Global-only: conflict_ok flips true, attendance_first appended to priority_rules",
        "merge_action": "global_only",
        "expected_parse": {"groups": [], "global": {"conflict_ok": true, "priority_rules": ["attendance_first"]}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 5, "gender": "M"}], "global": {"conflict_ok": true, "priority_rules": ["male_first", "attendance_first"]}, "is_confirming": false}
      }
    ]
  },
  {
    "category": "Multi-Turn Conversation",
    "type": "multi_turn",
    "test_id": "multiturn_003",
    "description": "Specification replaces then modifier applies: count+gender -> college spec (replaces) -> experience modifier",
    "note": "Specification turn (with college) fully resets the group list; subsequent modifiers patch the new groups",
    "conversation": [
      {
        "turn": 1,
        "input": "2 female volunteers",
        "description": "Initial: count + gender, no college",
        "merge_action": "initial",
        "expected_parse": {"groups": [{"count": 2, "gender": "F"}], "global": {"conflict_ok": false}, "is_confirming": false},
        "expected_merged": {"groups": [{"count": 2, "gender": "F"}], "global": {"conflict_ok": false, "priority_rules": []}, "is_confirming": false}
      },
      {
        "turn": 2,
        "input": "From CCE",
        "description": "Specification: college present -> replaces entire group list, prior count+gender are gone",
